{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Run Hex Server",
      "type": "shell",
      "command": "uv sync; uv build; uv run python start_servers.py",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "hexserver",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting WebSocket server|WebSocket server started|Servers running!",
          "endsPattern": "."
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    }
  ]
}
